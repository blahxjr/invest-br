// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  BROKERAGE
  BANK
  CRYPTO_WALLET
  REAL_ESTATE
  MANUAL
}

enum InstitutionType {
  BROKER
  BANK
  CRYPTO_EXCHANGE
  REAL_ESTATE_FUND
  OTHER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  clients       Client[]
  portfolios    Portfolio[]
  insightConfigProfileId    String?
  insightConfigProfile      InsightConfigProfile?  @relation("UserInsightProfile", fields: [insightConfigProfileId], references: [id])
  insightConfigProfilesOwned InsightConfigProfile[] @relation("InsightProfileOwner")
  sessions      Session[]
  accounts      AuthAccount[]
  allocationTargets AllocationTarget[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Client {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  name      String
  insightConfigProfileId String?
  insightConfigProfile   InsightConfigProfile? @relation("ClientInsightProfile", fields: [insightConfigProfileId], references: [id])
  accounts  Account[]
  portfolios Portfolio[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([insightConfigProfileId])
}

model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Portfolio {
  id          String    @id @default(cuid())
  name        String
  description String?
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id])
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  insightConfigProfileId String?
  insightConfigProfile   InsightConfigProfile? @relation("PortfolioInsightProfile", fields: [insightConfigProfileId], references: [id])
  accounts    Account[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([userId])
  @@index([insightConfigProfileId])
}

model Institution {
  id        String           @id @default(cuid())
  name      String
  type      InstitutionType?
  accounts  Account[]
  createdAt DateTime         @default(now())
}

model Account {
  id             String         @id @default(cuid())
  name           String
  type           AccountType
  brokerAccountNumber String?
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id])
  portfolioId    String?
  portfolio      Portfolio?     @relation(fields: [portfolioId], references: [id])
  institutionId  String
  institution    Institution    @relation(fields: [institutionId], references: [id])
  transactions   Transaction[]  @relation("PrimaryAccountTransactions")
  originTransactions Transaction[] @relation("OriginAccountTransactions")
  ledgerEntries  LedgerEntry[]
  incomeEvents   IncomeEvent[]
  positions      Position[]
  rentalReceipts RentalReceipt[]
  createdAt      DateTime       @default(now())

  @@unique([clientId, institutionId, name])
  @@unique([clientId, institutionId, brokerAccountNumber])
}

// ─── Catálogo de ativos ──────────────────────────────────────────────────────

enum AssetCategory {
  STOCK
  FII
  ETF
  FIXED_INCOME
  FUND
  CRYPTO
  METAL
  REAL_ESTATE
  CASH
  BDR
}

enum InvestmentHorizon {
  SHORT
  MEDIUM
  LONG
}

enum InsightProfileScope {
  GLOBAL
  USER
  CLIENT
  PORTFOLIO
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
}

model AssetClass {
  id                     String             @id @default(cuid())
  name                   String
  code                   String?            @unique
  description            String?
  recommendedHorizonBase InvestmentHorizon?
  assets                 Asset[]
  createdAt              DateTime           @default(now())
}

model Asset {
  id                 String             @id @default(cuid())
  name               String
  ticker             String?            @unique
  isin               String?            @unique
  cnpj               String?            @unique
  category           AssetCategory
  subtype            String?
  currency           String             @default("BRL")
  country            String?
  indexer            String?
  fixedRate          Decimal?           @db.Decimal(10, 6)
  emissionDate       DateTime?          @db.Date
  maturityDate       DateTime?          @db.Date
  recommendedHorizon InvestmentHorizon?
  assetClassId       String
  assetClass         AssetClass         @relation(fields: [assetClassId], references: [id])
  transactions       Transaction[]
  incomeEvents       IncomeEvent[]
  positions          Position[]
  prices             AssetPrice[]
  subscriptionRights SubscriptionRight[]
  createdAt          DateTime           @default(now())
}

model Position {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  quantity    Decimal  @db.Decimal(18, 8)
  totalCost   Decimal  @db.Decimal(18, 2)
  avgCost     Decimal  @db.Decimal(18, 8)
  lastUpdated DateTime @updatedAt

  @@unique([accountId, assetId])
}

model AssetPrice {
  id      String   @id @default(cuid())
  assetId String
  asset   Asset    @relation(fields: [assetId], references: [id])
  price   Decimal  @db.Decimal(18, 8)
  date    DateTime @db.Date
  source  String

  @@unique([assetId, date])
}

model InsightType {
  id               String             @id @default(cuid())
  code             String             @unique
  label            String
  description      String?
  defaultThreshold Decimal            @db.Decimal(6, 4)
  defaultSeverity  InsightSeverity    @default(WARNING)
  isActive         Boolean            @default(true)
  rules            InsightConfigRule[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model InsightConfigProfile {
  id                String              @id @default(cuid())
  name              String
  description       String?
  scope             InsightProfileScope
  isActive          Boolean             @default(true)
  isSystemDefault   Boolean             @default(false)
  ownerUserId       String?
  ownerUser         User?               @relation("InsightProfileOwner", fields: [ownerUserId], references: [id])
  rules             InsightConfigRule[]
  assignedUsers     User[]              @relation("UserInsightProfile")
  assignedClients   Client[]            @relation("ClientInsightProfile")
  assignedPortfolios Portfolio[]        @relation("PortfolioInsightProfile")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([scope, ownerUserId])
}

model InsightConfigRule {
  id                String              @id @default(cuid())
  profileId         String
  profile           InsightConfigProfile @relation(fields: [profileId], references: [id])
  insightTypeId     String
  insightType       InsightType         @relation(fields: [insightTypeId], references: [id])
  enabled           Boolean             @default(true)
  thresholdOverride Decimal?            @db.Decimal(6, 4)
  severityOverride  InsightSeverity?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([profileId, insightTypeId])
  @@index([insightTypeId])
}

// ─── Rebalanceamento e alocação ──────────────────────────────────────────────

model AllocationTarget {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetClass String  // 'RENDA_FIXA' | 'ACOES' | 'FIIS' | 'CRYPTO' | 'EXTERIOR' | 'OUTROS'
  targetPct Decimal  @db.Decimal(6, 2) // 0.00 a 100.00 (soma deve ser 100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, assetClass])
  @@index([userId])
}

// ─── Ledger ──────────────────────────────────────────────────────────────────

enum TransactionType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  DIVIDEND
  INCOME
  RENT
  CUSTODY_TRANSFER
  SUBSCRIPTION_RIGHT
  SUBSCRIPTION_EXPIRED
  RIGHTS_TRANSFER
  RIGHTS_TRANSFER_PENDING
  CORPORATE_UPDATE
  MATURITY
  SPLIT
  BONUS_SHARES
  FRACTIONAL_DEBIT
  FRACTIONAL_AUCTION
}

enum SubscriptionStatus {
  PENDING
  EXERCISED
  EXPIRED
  TRANSFERRED
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model LedgerAccount {
  id          String            @id @default(cuid())
  name        String
  code        String            @unique
  type        LedgerAccountType
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  ledgerEntries LedgerEntry[]
}

model Transaction {
  id           String          @id @default(cuid())
  referenceId  String          @unique // chave de idempotência
  type         TransactionType
  accountId    String
  account      Account         @relation("PrimaryAccountTransactions", fields: [accountId], references: [id])
  originAccountId String?
  originAccount Account?       @relation("OriginAccountTransactions", fields: [originAccountId], references: [id])
  assetId      String?
  asset        Asset?          @relation(fields: [assetId], references: [id])
  quantity     Decimal?        @db.Decimal(18, 8)
  price        Decimal?        @db.Decimal(18, 8)
  totalAmount  Decimal         @db.Decimal(18, 2)
  date         DateTime
  sourceMovementType String?
  isTaxExempt  Boolean         @default(false)
  subscriptionDeadline DateTime?
  notes        String?
  ledgerEntries LedgerEntry[]
  incomeEvents  IncomeEvent[]
  subscriptionRights SubscriptionRight[]
  createdAt    DateTime        @default(now())
  deletedAt    DateTime?       // soft delete

  @@index([originAccountId])
}

model LedgerEntry {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  accountId     String
  account       Account     @relation(fields: [accountId], references: [id])
  ledgerAccountId String?
  ledgerAccount   LedgerAccount? @relation(fields: [ledgerAccountId], references: [id])
  debit         Decimal?    @db.Decimal(18, 2)
  credit        Decimal?    @db.Decimal(18, 2)
  movementType  String?
  description   String?
  isIncoming    Boolean     @default(true)
  balanceAfter  Decimal     @db.Decimal(18, 2)
  createdAt     DateTime    @default(now())

  @@index([ledgerAccountId])
}

model SubscriptionRight {
  id                String             @id @default(cuid())
  transactionId     String
  transaction       Transaction        @relation(fields: [transactionId], references: [id])

  assetId           String
  asset             Asset              @relation(fields: [assetId], references: [id])

  quantity          Decimal            @db.Decimal(18, 8)
  subscriptionPrice Decimal?           @db.Decimal(18, 8)

  deadline          DateTime?
  status            SubscriptionStatus @default(PENDING)

  exercisedQty      Decimal?           @db.Decimal(18, 8)
  expirationTxId    String?

  createdAt         DateTime           @default(now())

  @@index([transactionId])
  @@index([assetId])
  @@index([status])
}

// ─── Proventos e aluguéis ────────────────────────────────────────────────────

enum IncomeType {
  DIVIDEND
  JCP
  FII_RENT
  COUPON
  RENTAL
}

model IncomeEvent {
  id            String      @id @default(cuid())
  type          IncomeType
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  accountId     String
  account       Account     @relation(fields: [accountId], references: [id])
  assetId       String?
  asset         Asset?      @relation(fields: [assetId], references: [id])
  grossAmount   Decimal     @db.Decimal(18, 2)
  taxAmount     Decimal?    @db.Decimal(18, 2)
  netAmount     Decimal     @db.Decimal(18, 2)
  paymentDate   DateTime
  notes         String?
  createdAt     DateTime    @default(now())
  deletedAt     DateTime?       // soft delete
}

model RentalReceipt {
  id           String   @id @default(cuid())
  propertyName String
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id])
  grossRent    Decimal  @db.Decimal(18, 2)
  expenses     Decimal? @db.Decimal(18, 2)
  netRent      Decimal  @db.Decimal(18, 2)
  paymentDate  DateTime
  createdAt    DateTime @default(now())
}

// ─── Auditoria ──────────────────────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())
  entityType    String      // 'TRANSACTION', 'INCOME', 'ASSET'
  entityId      String      // ID da entidade auditada (Transaction.id ou IncomeEvent.id)
  action        String      // 'CREATE', 'UPDATE', 'DELETE'
  previousValue String?     // JSON serializado (null para CREATE)
  newValue      String?     // JSON serializado (null para DELETE)
  changedBy     String?     // userId
  changedAt     DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([changedAt])
}